# === Güvenlik ayarları (siteyi bozmadan, sadece koruma) ===

# Klasör içeriğinin listelenmesini engelle (örn. /uploads/ listesi görünmesin)
Options -Indexes

# Hassas yapılandırma dosyalarına doğrudan web erişimini engelle.
# Bu dosyalar sadece başka PHP dosyaları tarafından include edilir,
# tarayıcıdan doğrudan çağrılmaları gerekmez.
<FilesMatch "^(db|secrets|secrets\.example|push_config|mail_helper)\.php$">
    Require all denied
</FilesMatch>

# Log, yedek, sql ve yapılandırma dosyalarına erişimi engelle
<FilesMatch "(\.(sql|log|bak|ini|lock|yml|yaml)$|^error_log$)">
    Require all denied
</FilesMatch>

# Büyük cron log dosyaları
<Files "cron_log.txt">
    Require all denied
</Files>
<Files "cron_output.txt">
    Require all denied
</Files>

# Nokta ile başlayan gizli dosyalar (.git, .env, .user.ini vb.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Sınav PDF'lerine DOĞRUDAN erişimi engelle (öğrenci kişisel verisi - KVKK).
# Bu dosyalar yalnızca giriş yapmış kullanıcılara dosya.php üzerinden sunulur.
RewriteEngine On

# www → www'suz KANONİK yönlendirme. Oturum çerezi host'a özel olduğundan
# www.derspros.com.tr ile derspros.com.tr İKİ AYRI oturum demekti; öğretmen
# www'lu adreste kalınca PDF/WhatsApp gönderimi "Yetkisiz erişim" veriyordu.
# Tek adrese sabitleyerek kökten çözülür (test alt alanında da zararsızdır).
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# assets/uploads/ (legacy upload_exam.php sınav PDF'leri) doğrudan indirmeye açık
# kalmalı ama çalıştırılabilir uzantılara kapalı — aynı savunma katmanı.
RewriteRule ^assets/uploads/.*\.(php[0-9]?|phtml|phar|pl|py|cgi|sh|asp|aspx|jsp)$ - [F,L,NC]

# uploads/ kökü (admin/materyal.php materyalleri) doğrudan indirmeye açık kalmalı
# ama ÇALIŞTIRILABİLİR dosya uzantıları asla sunulmamalı — sunucu tarafı MIME
# doğrulaması zaten uzantıyı kendisi üretiyor, bu ek bir savunma katmanıdır
# (uzantı doğrulaması bir şekilde atlatılsa bile RCE'yi engeller).
RewriteRule ^uploads/.*\.(php[0-9]?|phtml|phar|pl|py|cgi|sh|asp|aspx|jsp)$ - [F,L,NC]

RewriteRule ^uploads/exams/ - [F,L]

# Ödeme dekontlarına DOĞRUDAN erişimi engelle (mali/kişisel veri).
# Yalnızca ödemenin sahibi öğretmene koc/dekont.php üzerinden sunulur.
RewriteRule ^uploads/receipts/ - [F,L]

# Composer kütüphane dosyalarına doğrudan web erişimi gereksiz — kapat.
RewriteRule ^vendor/ - [F,L]

# Veritabanı yedeklerine DOĞRUDAN erişimi engelle (indirme yalnızca
# oturumlu admin ile admin/yedekler.php üzerinden yapılır).
RewriteRule ^backups/ - [F,L]

# LiteSpeed sunucu önbelleği (LSCache) .php sayfalarını devre dışı bırakır.
# Site tamamen oturum tabanlı/dinamik olduğundan sayfa önbelleklenmesi
# deploy sonrası değişikliklerin (header/footer gibi) gecikmeli görünmesine yol açar.
<IfModule LiteSpeed>
    CacheLookup off
</IfModule>
